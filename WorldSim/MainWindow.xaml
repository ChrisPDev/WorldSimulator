<Window x:Class="WorldSim.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WorldSim"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="25"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="25"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="7*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="25"/>
        </Grid.RowDefinitions>

        <Label
            x:Name="SimulatorTitleLbl"
            Grid.Column="1"
            Grid.Row="1"
            Content="World"
            FontFamily="Tahoma"
            FontSize="25"
            FontWeight="Bold"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"/>
        <Label
            x:Name="LogTitleLbl"
            Grid.Column="2"
            Grid.Row="1"
            Content="Event Log"
            FontFamily="Tahoma"
            FontSize="25"
            FontWeight="Bold"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"/>
        <Label
            x:Name="ActionsTitleLbl"
            Grid.Column="3"
            Grid.Row="1"
            Content="Actions"
            FontFamily="Tahoma"
            FontSize="25"
            FontWeight="Bold"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"/>

        <Border
            x:Name="SimulatorBorder"
            Grid.Column="1"
            Grid.Row="2"
            BorderBrush="Black"
            BorderThickness="1"
            Margin="10">
            
            <!-- ItemsControl with databinding incomming soon -->
        </Border>
        
        <Label
            x:Name="CoordinatesLbl"
            Grid.Column="1"
            Grid.Row="3"
            Content="Coordinates: "
            FontFamily="Tahoma"
            FontSize="15"
            FontWeight="Bold"
            HorizontalContentAlignment="Left"
            VerticalContentAlignment="Center"/>
    </Grid>
</Window>
